// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  
  assignedAppointments  ViewingAppointment[] @relation("Assignee")
  createdTickets        RegistrationTicket[] @relation("TicketCreator")
  assignedTickets       RegistrationTicket[] @relation("TicketAssignee")
  createdDeposits       DepositTicket[]      @relation("DepositCreator")
  confirmedDeposits     DepositTicket[]      @relation("DepositConfirmer")
  payments              Payment[]            @relation("PaymentStaff")
  createdContracts      Contract[]           @relation("ContractCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  
  users         User[]
  rooms         Room[]
  registrations RegistrationTicket[]
  appointments  ViewingAppointment[]
  deposits      DepositTicket[]
  contracts     Contract[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Room {
  id            String   @id @default(uuid())
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id])
  
  name          String
  capacity      Int
  occupancy     Int      @default(0)
  price         Float          // Giá tham khảo (giá thực tế theo từng Giường)
  status        String   @default("AVAILABLE") // AVAILABLE, FULL, MAINTENANCE

  beds          Bed[]
  appointments  ViewingAppointment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  consultingTickets RegistrationTicket[] @relation("TicketToRoom")
}

// Giường — Đơn vị cho thuê nhỏ nhất (theo ERD)
model Bed {
  id            String   @id @default(uuid())
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id])
  
  position      String           // VD: "Trên-1", "Dưới-1", "Trên-2", "Dưới-2"
  price         Float            // Đơn giá thuê/tháng
  status        String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, DEPOSITED, MAINTENANCE

  depositDetails DepositDetail[]
  contractDetails ContractBedDetail[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RegistrationTicket {
  id                    String   @id @default(uuid())
  branchId              String
  branch                Branch   @relation(fields: [branchId], references: [id])
  
  // Customer Info (Khách thuê)
  cccd                  String?    // Căn cước công dân
  customerName          String
  phoneNumber           String
  email                 String?
  dateOfBirth           DateTime?  // Ngày sinh
  gender                String?
  address               String?    // Địa chỉ thường trú
  
  // Rental Requirements (Yêu cầu thuê)
  rentalType            String?    // Hình thức thuê: nguyen_can, o_ghep
  roomTypePreference    String?    // Loại phòng mong muốn: ktx, studio, 1pn
  headcount             Int?       // Số lượng người ở
  preferredArea         String?    // Khu vực mong muốn
  minPrice              Float?     // Mức giá tối thiểu
  maxPrice              Float?     // Mức giá tối đa
  rentalDuration        String?    // Thời hạn thuê: 6m, 12m
  moveInDate            DateTime?  // Thời gian dự kiến vào ở
  contactChannel        String?    // Kênh tiếp nhận: facebook, zalo, hotline, referral
  additionalPreferences String?    // Tiêu chí ưu tiên khác
  
  // Status tracking
  status                String   @default("DRAFT") // DRAFT, CONSULTING, WAITING_VIEW, WAITLIST, CANCELLED, COMPLETED
  cancelReason          String?
  
  // Staff relations (Nhân viên)
  createdById           String?
  createdBy             User?    @relation("TicketCreator", fields: [createdById], references: [id])
  assignedStaffId       String?
  assignedStaff         User?    @relation("TicketAssignee", fields: [assignedStaffId], references: [id])
  
  appointments          ViewingAppointment[]
  consultingRooms       Room[]               @relation("TicketToRoom")
  deposits              DepositTicket[]
  contracts             Contract[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ViewingAppointment {
  id                    String   @id @default(uuid())
  registrationId        String
  registration          RegistrationTicket @relation(fields: [registrationId], references: [id])
  
  branchId              String
  branch                Branch   @relation(fields: [branchId], references: [id])
  
  roomId                String?
  room                  Room?    @relation(fields: [roomId], references: [id])
  
  assigneeId            String?
  assignee              User?    @relation("Assignee", fields: [assigneeId], references: [id])
  
  datetime              DateTime
  meetingLocation       String?    // Nơi hẹn
  status                String   @default("UPCOMING") // UPCOMING, VIEWED, CANCELLED
  viewingResult         String?    // Kết quả sau khi xem
  resultNote            String?    // Ghi chú kết quả
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Phiếu đặt cọc (theo ERD)
model DepositTicket {
  id                    String   @id @default(uuid())
  registrationId        String
  registration          RegistrationTicket @relation(fields: [registrationId], references: [id])
  
  branchId              String
  branch                Branch   @relation(fields: [branchId], references: [id])
  
  depositAmount         Float            // Số tiền cọc (tự động tính)
  depositPercent        Float?           // Phần trăm cọc (null = dùng công thức mặc định 2 tháng)
  depositedAt           DateTime?        // Thời điểm cọc thực tế
  paymentDeadline       DateTime         // Hạn thanh toán (createdAt + 24h)
  status                String   @default("PENDING") // PENDING, PAID, CONFIRMED, CANCELLED, EXPIRED
  cancelReason          String?
  
  // Staff
  createdById           String?
  createdBy             User?    @relation("DepositCreator", fields: [createdById], references: [id])
  confirmedById         String?
  confirmedBy           User?    @relation("DepositConfirmer", fields: [confirmedById], references: [id])
  confirmedAt           DateTime?
  
  details               DepositDetail[]
  payments              Payment[]
  contract              Contract?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Chi tiết phiếu đặt cọc (theo ERD: composite key Mã phiếu + Mã giường)
model DepositDetail {
  id                    String   @id @default(uuid())
  
  depositTicketId       String
  depositTicket         DepositTicket @relation(fields: [depositTicketId], references: [id])
  
  bedId                 String
  bed                   Bed      @relation(fields: [bedId], references: [id])
  
  receiptLotNumber      String?  // Số lô biên nhận

  @@unique([depositTicketId, bedId])
}

// Thanh toán (theo ERD — dùng chung cho mọi loại giao dịch)
model Payment {
  id                    String   @id @default(uuid())
  
  depositTicketId       String?
  depositTicket         DepositTicket? @relation(fields: [depositTicketId], references: [id])
  
  paymentType           String         // DEPOSIT, RENT, SERVICE, REFUND
  documentType          String?        // RECEIPT, BANK_TRANSFER, INVOICE
  amount                Float          // Số tiền
  paymentMethod         String?        // CASH, TRANSFER
  paymentTime           DateTime?      // Thời điểm thanh toán
  status                String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  transactionId         String?        // Mã giao dịch (chuyển khoản)
  content               String?        // Nội dung thanh toán
  note                  String?        // Ghi chú
  
  staffId               String?
  staff                 User?    @relation("PaymentStaff", fields: [staffId], references: [id])
  proofUrl              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================================================
// CONTRACT MODELS - Nhận phòng & Lập hợp đồng
// ============================================================================

enum ContractStatus {
  ACTIVE      // Hợp đồng đang hiệu lực
  CANCELLED   // Hợp đồng bị hủy
  ENDED       // Hợp đồng đã kết thúc
}

enum ContractRentalType {
  WHOLE_ROOM  // Thuê nguyên căn
  BEDS        // Thuê theo giường (ở ghép)
}

enum PaymentCycle {
  MONTHLY     // Thanh toán hàng tháng
  QUARTERLY   // Thanh toán hàng quý
}

enum OccupantGender {
  MALE
  FEMALE
  OTHER
}

// Hợp đồng thuê
model Contract {
  id              String   @id @default(uuid())
  code            String   @unique  // Mã hợp đồng (VD: HD001)

  // Liên kết nguồn
  registrationId  String
  registration    RegistrationTicket @relation(fields: [registrationId], references: [id])

  depositTicketId String   @unique  // 1 phiếu cọc chỉ tạo 1 hợp đồng
  depositTicket   DepositTicket @relation(fields: [depositTicketId], references: [id])

  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id])

  // Thông tin hợp đồng
  rentalType      ContractRentalType  // Tự động suy ra từ số giường
  paymentCycle    PaymentCycle @default(MONTHLY)
  status          ContractStatus @default(ACTIVE)

  startDate       DateTime
  endDate         DateTime?  // Nullable nếu chưa xác định
  depositAmount   Float      // Snapshot từ DepositTicket
  monthlyRent     Float      // Tổng giá thuê/tháng
  serviceFee      Float      @default(0)  // Phí dịch vụ
  note            String?

  // Xác nhận nhận phòng (bắt buộc trước khi tạo hợp đồng)
  checkInConfirmed        Boolean @default(false)
  roomConditionConfirmed  Boolean @default(false)
  documentConfirmed       Boolean @default(false)

  // Staff
  createdById     String?
  createdBy       User?    @relation("ContractCreator", fields: [createdById], references: [id])

  // Relations
  bedDetails      ContractBedDetail[]
  occupants       ContractOccupant[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Chi tiết giường trong hợp đồng (snapshot giá tại thời điểm ký)
model ContractBedDetail {
  id             String   @id @default(uuid())

  contractId     String
  contract       Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  bedId          String
  bed            Bed      @relation(fields: [bedId], references: [id])

  priceAtSigning Float    // Giá thuê/tháng tại thời điểm ký
  startDate      DateTime // Ngày bắt đầu thuê giường này
  endDate        DateTime? // Ngày kết thúc (nullable)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([contractId, bedId])
}

// Người ở trong hợp đồng
model ContractOccupant {
  id             String   @id @default(uuid())

  contractId     String
  contract       Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  fullName       String
  identityNumber String         // CCCD/CMND
  gender         OccupantGender
  dateOfBirth    DateTime
  nationality    String   @default("Việt Nam")
  isRepresentative Boolean @default(false)  // Người đại diện hợp đồng

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
